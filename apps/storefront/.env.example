# Base URL of the shared Medusa backend (server-side calls only).
MEDUSA_BACKEND_URL=http://localhost:9000

# Shared secret for the storefront -> Medusa trusted channel. MUST match the
# Medusa backend's SELFKART_STOREFRONT_SECRET. The storefront server signs the
# Host (to call /selfkart/resolve-domain) and the resolved tenant_id (to call
# /store*). The browser never holds this and never asserts a tenant.
SELFKART_STOREFRONT_SECRET=replace-with-32-plus-chars-matching-medusa

# Base domain that tenant storefronts are subdomains of (e.g. "myselfkart.com",
# or "localhost" in dev). Used to scope the customer session cookie to `.<base>`
# so the single Google OAuth callback host can set a session the tenant subdomain
# then reads. Leave unset for host-only cookies (Google login cross-subdomain
# handoff then only works same-origin).
SELFKART_STOREFRONT_BASE_DOMAIN=localhost

# The single, registered Google OAuth redirect URL (must exactly match one entry
# in the Google Cloud console and the backend's GOOGLE_CALLBACK_URL). Google sends
# buyers here after consent; this app completes the exchange and bounces them back
# to their store. Must be under SELFKART_STOREFRONT_BASE_DOMAIN.
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
