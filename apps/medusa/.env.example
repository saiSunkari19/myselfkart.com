MIGRATOR_DATABASE_URL=postgresql://neondb_owner:REPLACE_ME@REPLACE_ME/neondb?sslmode=require
APP_DATABASE_URL=postgresql://medusa_app:REPLACE_ME@REPLACE_ME-pooler.REPLACE_ME/neondb?sslmode=require
DATABASE_URL=postgresql://medusa_app:REPLACE_ME@REPLACE_ME-pooler.REPLACE_ME/neondb?sslmode=require
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:7001,http://localhost:9000
AUTH_CORS=http://localhost:7001,http://localhost:9000
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-32-plus-chars
COOKIE_SECRET=replace-with-32-plus-chars

# Storefront base domain (e.g. myselfkart.com). When set, STORE_CORS + AUTH_CORS
# additionally allow every subdomain of it via a regex, so tenant storefronts can
# call /store* + /store/auth without enumerating each host.
SELFKART_STOREFRONT_BASE_DOMAIN=localhost

# Customer Google OAuth (optional — emailpass always works without it). One Google
# client for the whole platform. GOOGLE_CALLBACK_URL is the single registered
# redirect URI; it points at the STOREFRONT callback page, not Medusa. Set all
# three or none.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Resend notification provider (preferred for "email"; Resend -> SendGrid -> local).
# RESEND_FROM is the fallback sender for platform mail; buyer mail is sent as
# "<Store>" <store+<tenant_id>@SELFKART_EMAIL_DOMAIN>. SELFKART_EMAIL_DOMAIN defaults
# to the domain of RESEND_FROM (e.g. myselfkart.com).
RESEND_API_KEY=
RESEND_FROM=noreply@myselfkart.com
RESEND_REPLY_TO=connect@myselfkart.com
SELFKART_EMAIL_DOMAIN=myselfkart.com

# Shiprocket shipment-status webhook secret. Set the SAME value here and in the
# Shiprocket panel (Settings -> API -> Webhook -> Token, Auth Token Type x-api-key).
# Webhook URL to register there: https://api.myselfkart.com/webhooks/delivery/<tenant_id>
SHIPROCKET_WEBHOOK_SECRET=

# SendGrid notification provider (legacy fallback). Used for "email" only if RESEND
# is not configured. SENDGRID_PASSWORD_RESET_TEMPLATE is a SendGrid dynamic-template id.
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_PASSWORD_RESET_TEMPLATE=
