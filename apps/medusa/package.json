{
  "name": "@selfkart/medusa-backend",
  "version": "0.1.0",
  "description": "Selfkart Medusa backend for the Phase 0B Neon RLS isolation gate",
  "private": true,
  "packageManager": "pnpm@9.15.2",
  "main": "medusa-config.ts",
  "scripts": {
    "dev": "medusa develop",
    "build": "medusa build",
    "start": "medusa start",
    "db:migrate": "medusa db:migrate",
    "delete:seller-products": "medusa exec ./src/scripts/delete-seller-products.ts",
    "prepare:seller-import": "medusa exec ./src/scripts/prepare-seller-product-import.ts",
    "link:seller-taxonomy": "medusa exec ./src/scripts/seed-tenant-product-taxonomy.ts",
    "seed:tenants": "medusa exec ./src/scripts/seed-tenants.ts",
    "provision:storefront": "medusa exec ./src/scripts/provision-tenant-storefront.ts",
    "provision:commerce": "medusa exec ./src/scripts/provision-tenant-commerce.ts",
    "test": "node --test --test-concurrency=1 tests/integration/rls/*.test.js tests/integration/import/*.test.js",
    "test:rls": "node --test --test-concurrency=1 tests/integration/rls/*.test.js",
    "test:import": "node --test --test-concurrency=1 tests/integration/import/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/js-sdk": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/utils": "2.15.5"
  },
  "devDependencies": {
    "knex": "3.2.8",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "@medusajs/utils@2.15.5": "patches/@medusajs__utils@2.15.5.patch",
      "@mikro-orm/knex@6.6.12": "patches/@mikro-orm__knex@6.6.12.patch"
    }
  }
}
